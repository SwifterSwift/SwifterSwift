--closingparen same-line
--commas inline
--disable redundantReturn,wrapMultilineStatementBraces,wrapFunctionBodies,wrapPropertyBodies
--exclude Examples
--guardelse same-line
--header "{file} - Copyright {year} SwifterSwift"
--ifdef no-indent
--importgrouping testable-top
--nospaceoperators ..<,...
--maxwidth 120
